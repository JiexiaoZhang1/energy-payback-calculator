{
  "name": "energy-payback-calculator",
  "version": "0.1.0",
  "description": "A bilingual household energy savings and payback calculator for time-of-use and negative electricity tariffs.",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/JiexiaoZhang1/energy-payback-calculator.git"
  },
  "homepage": "https://jiexiaozhang1.github.io/energy-payback-calculator/",
  "keywords": [
    "energy",
    "payback",
    "calculator",
    "time-of-use",
    "negative-pricing",
    "react",
    "vite"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "server": "node server/index.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "start": "node server/index.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.468.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^10.0.3",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.16"
  }
}
